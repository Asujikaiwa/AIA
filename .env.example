# Lead form webhook (Zapier / Make / Slack / Discord / n8n / etc.)
LEAD_WEBHOOK_URL=

# Optional client-side override for the form endpoint
# (defaults to "/api/lead" if not set)
NEXT_PUBLIC_LEAD_WEBHOOK=

# Google Analytics 4 Measurement ID (เช่น G-XXXXXXXXXX)
# ดู: https://analytics.google.com -> Admin -> Data Streams -> Web
# ปล่อยว่างถ้ายังไม่อยากเก็บข้อมูล GA จะไม่โหลด
NEXT_PUBLIC_GA_ID=

# Base URL ของ PDF + thumbnail บน Cloud Storage (ไม่ต้องมี trailing slash)
# ตัวอย่าง:
#   Cloudflare R2:     https://pub-xxxxxxxx.r2.dev
#   AWS S3 public:     https://my-bucket.s3.ap-southeast-1.amazonaws.com
#   B2 + CDN (bunny):  https://aia.b-cdn.net
# ถ้าปล่อยว่างจะ fallback กลับใช้ /public/brochures/ ใน repo
NEXT_PUBLIC_BROCHURE_CDN=
