# ============================================================================
# .env.example — คัดลอกเป็น .env.local แล้วใส่ค่าจริง (จะไม่ commit ขึ้น git)
# สำหรับ production: ตั้งใน Vercel → Project Settings → Environment Variables
# ============================================================================

# ── LINE Messaging API (สำหรับแจ้งเตือน lead เข้า LINE) ─────────────────────
# ⚠ เก็บเป็นความลับ ห้าม commit ขึ้น git เด็ดขาด
# 1. สร้าง LINE Official Account + Messaging API channel ที่ https://developers.line.biz
# 2. คัดลอก Channel Access Token (long-lived)
# 3. ใส่ตรงนี้:
LINE_ACCESS_TOKEN=iW94iqnpd7DS9UE6NaYuayNHCPCrXn+4Mg4a9GLUDMoU58xIG/s2EBcvVshSd9Lsur5B74JK3vSGFEVg+VVN8nse/ZWqKLnLpaDqzKxpnjEunHtZ7GfxbGtIx2Yt97F3wmuBiNJTmr7lO94jQUuohgdB04t89/1O/w1cDnyilFU=

# LINE User ID ของผู้รับข้อความ (ตัวเลข/ตัวอักษรขึ้นต้นด้วย U)
# วิธีหา: ส่งข้อความหา bot ของตัวเอง แล้วเช็คจาก webhook log
LINE_USER_ID=U2f698231a14d6ebf30ad38d847233d05

# ── (ไม่ใช้แล้ว) Webhook อื่น ─────────────────────────────────────────────
# ตอนนี้ /api/lead ส่งตรงเข้า LINE ผ่าน LINE_ACCESS_TOKEN ด้านบน
# ถ้าจะใช้ webhook อื่น (Zapier/Make/Discord) เพิ่มเองได้
LEAD_WEBHOOK_URL=

# ถ้าตั้งค่านี้ ฟอร์มจะส่งไป URL นี้แทน /api/lead
# ปล่อยว่างเพื่อใช้ /api/lead (ปลอดภัยกว่าเพราะ token ไม่ออกไปฝั่ง client)
NEXT_PUBLIC_LEAD_WEBHOOK=

# ── Google Analytics 4 ─────────────────────────────────────────────────────
# Measurement ID (เช่น G-XXXXXXXXXX)
# ดู: https://analytics.google.com -> Admin -> Data Streams -> Web
# ปล่อยว่างถ้ายังไม่อยากเก็บข้อมูล (GA จะไม่โหลด)
NEXT_PUBLIC_GA_ID=

# ── Cloudflare R2 / S3 / B2 (โบรชัวร์ PDF) ─────────────────────────────────
# Base URL ของ PDF + thumbnail บน Cloud Storage (ไม่ต้องมี trailing slash)
# ตัวอย่าง:
#   Cloudflare R2:     https://pub-xxxxxxxx.r2.dev
#   AWS S3 public:     https://my-bucket.s3.ap-southeast-1.amazonaws.com
#   B2 + CDN (bunny):  https://aia.b-cdn.net
# ถ้าปล่อยว่างจะ fallback กลับใช้ /public/brochures/ ใน repo
NEXT_PUBLIC_BROCHURE_CDN=
