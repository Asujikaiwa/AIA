# ============================================================================
# .env.example — ไฟล์ TEMPLATE ที่ commit ขึ้น git ได้
# ⚠ ห้ามใส่ค่าจริง / token จริง / password ที่นี่เด็ดขาด!
# วิธีใช้: คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงในนั้นแทน
# สำหรับ production: ตั้งใน Vercel → Project Settings → Environment Variables
# ============================================================================

# ── LINE Messaging API (สำหรับแจ้งเตือน lead เข้า LINE) ─────────────────────
# 1. สร้าง LINE Official Account + Messaging API channel ที่ https://developers.line.biz
# 2. คัดลอก Channel Access Token (long-lived)
LINE_ACCESS_TOKEN=

# LINE User ID ของผู้รับข้อความ (ขึ้นต้นด้วย U ตามด้วย hash 32 ตัว)
LINE_USER_ID=

# ── (ทางเลือก) webhook อื่น แทนการส่งตรงเข้า LINE ───────────────────────────
LEAD_WEBHOOK_URL=

# ถ้าตั้งค่านี้ ฟอร์มจะ POST ไป URL นี้แทน /api/lead
NEXT_PUBLIC_LEAD_WEBHOOK=

# ── Google Analytics 4 ─────────────────────────────────────────────────────
# Measurement ID (เช่น G-XXXXXXXXXX) — ปล่อยว่าง = GA ไม่โหลด
NEXT_PUBLIC_GA_ID=

# ── Cloudflare R2 / S3 / B2 (โบรชัวร์ PDF) ─────────────────────────────────
# ตัวอย่าง: https://pub-xxxxxxxx.r2.dev
# ปล่อยว่างจะ fallback ใช้ /public/brochures/
NEXT_PUBLIC_BROCHURE_CDN=
